# ═══════════════════════════════════════════════════════════════
# PREDIKT.ai Environment Variables Template
# Copy this to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ──── GENLAYER BRADBURY (Intelligent Contracts) ─────────────────
# Use https://bradbury.genlayer.com/rpc for Testnet (Requires Faucet)
# Use https://studio.genlayer.com/api for Studio Simulator (Faucet-Free)
GENLAYER_RPC_URL=https://bradbury.genlayer.com/rpc
CONTRACT_ADDRESS=0x9e1a258598b8a698c20d1a5621c86f1733a8e2e7fb069b230c191f2b28e4ba49
OWNER_PRIVATE_KEY=

# ──── BASE SEPOLIA (ERC-20 Token & Staking) ─────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_MOCK_USDL_ADDRESS=
NEXT_PUBLIC_BET_FACTORY_ADDRESS=
NEXT_PUBLIC_FAUCET_ADDRESS=

# ──── FRONTEND CONFIGURATION ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=0x9e1a258598b8a698c20d1a5621c86f1733a8e2e7fb069b230c191f2b28e4ba49

# ──── WALLET INTEGRATION (Privy) ─────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# ──── DATABASE (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/PREDIKT_db

# ──── LLM APIS (AI Debate Engine) ────────────────────────────────
OPENAI_API_KEY=sk_live_xxxxxxxxxxxx
ANTHROPIC_API_KEY=sk_ant_xxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSy_xxxxxxxxxxxx
TOGETHER_API_KEY=xxxxxxxxxxxx
VENICE_API_KEY=xxxxxxxxxxxx

# ──── DEPLOYMENT ────────────────────────────────────────────────
NODE_ENV=development
PRIVATE_KEY=
BASESCAN_API_KEY=
